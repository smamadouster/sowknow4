# ============================================================================
# ⚠️ SECURITY WARNING - NEVER COMMIT REAL CREDENTIALS ⚠️
# ============================================================================
# This file is tracked in git. NEVER include real API keys, secrets, or tokens.
# Copy this file to .env and fill in your actual values.
# Use a password manager or secure vault to generate and store credentials.
# All credentials in this file have been replaced with placeholders.
# ============================================================================

# ============================================================================
# SECURITY CONFIGURATION - CRITICAL FOR PRODUCTION
# ============================================================================
# These settings control CORS and TrustedHost security middleware.
# In production, BOTH must be set to prevent security vulnerabilities.

# ALLOWED_ORIGINS: Comma-separated list of allowed frontend origins
#   - NEVER use wildcard "*" with credentials (security vulnerability)
#   - Must include full URLs with protocol (http:// or https://)
#   - Required in production, defaults to localhost in development
#   - Example Production: https://sowknow.gollamtech.com,https://www.sowknow.gollamtech.com
#   - Example Development: http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ALLOWED_HOSTS: Comma-separated list of allowed hostnames
#   - Prevents Host header injection attacks
#   - Use "*" only for development (insecure in production)
#   - Required in production, defaults to wildcard in development
#   - Example Production: sowknow.gollamtech.com,www.sowknow.gollamtech.com
#   - Example Development: *
ALLOWED_HOSTS=*

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_PASSWORD=YOUR_DATABASE_PASSWORD_HERE
JWT_SECRET=YOUR_JWT_SECRET_HERE
REDIS_PASSWORD=YOUR_STRONG_REDIS_PASSWORD_HERE

# ============================================================================
# EXTERNAL APIS
# ============================================================================

# MiniMax API (M2.5) - Primary LLM for all public document interactions
# Get your key at https://platform.minimax.io
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY_HERE
# MINIMAX_MODEL: MiniMax model to use (default: MiniMax-M2.5)
MINIMAX_MODEL=MiniMax-M2.5

# Kimi (Moonshot AI) - Direct API for Telegram bot
# ⚠️ ROTATE THIS KEY IMMEDIATELY - exposed in public repository
KIMI_API_KEY=YOUR_KIMI_API_KEY_HERE

# OpenRouter API - Fallback LLM (Kimi K2.5) when MiniMax direct is unavailable
# OPENROUTER_API_KEY: Your OpenRouter API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
# OPENROUTER_MODEL: Kimi K2.5 via OpenRouter (fallback path)
OPENROUTER_MODEL=moonshotai/kimi-k2.5
# OPENROUTER_BASE_URL: OpenRouter API base URL (usually don't change)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL: Your site URL for rankings on openrouter.ai
OPENROUTER_SITE_URL=https://sowknow.gollamtech.com
# OPENROUTER_SITE_NAME: Your site name
OPENROUTER_SITE_NAME=SOWKNOW

# ============================================================================
# OCR CONFIGURATION (PaddleOCR + Tesseract)
# ============================================================================
# PaddleOCR: Primary OCR engine (CPU-based, multilingual)
# Tesseract: Fallback OCR engine (CPU-based, open source)
# All OCR processing is done locally - zero PII sent to cloud APIs
# Modes: base (1024x1024), large (1280x1280), gundam (multi-pass)
OCR_ENGINE=paddle
OCR_FALLBACK_ENABLED=true
OCR_DEFAULT_MODE=base

# ============================================================================
# TELEGRAM INTEGRATION
# ============================================================================
# TELEGRAM_BOT_TOKEN: Get from @BotFather on Telegram
# ⚠️ ROTATE IMMEDIATELY if this was ever committed to the repository
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# BOT_API_KEY: Internal API key used by the Telegram bot to authenticate
# with the SOWKNOW backend. Generate with: openssl rand -hex 32
# ⚠️ ROTATE IMMEDIATELY if this was ever committed to the repository
BOT_API_KEY=YOUR_BOT_API_KEY_HERE

# ============================================================================
# ADMIN ACCOUNT
# ============================================================================
# ⚠️ ROTATE THIS PASSWORD IMMEDIATELY - exposed in public repository
ADMIN_EMAIL=YOUR_ADMIN_EMAIL_HERE
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE
ADMIN_NAME=System Administrator

# ============================================================================
# LOCAL LLM CONFIGURATION
# ============================================================================
LOCAL_LLM_URL=http://host.docker.internal:11434

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# APP_ENV: Environment mode (development, staging, production)
#   - development: Permissive CORS/Host settings, detailed error messages
#   - production: Strict security, requires ALLOWED_ORIGINS and ALLOWED_HOSTS
APP_ENV=development
APP_NAME=SOWKNOW
APP_VERSION=1.0.0

# ============================================================================
# CELERY TASK QUEUE CONFIGURATION
# ============================================================================
# CELERY_VISIBILITY_TIMEOUT: Seconds before an unacknowledged task is re-queued
# Must be greater than CELERY_TASK_TIME_LIMIT. Default: 7200 (2 hours)
CELERY_VISIBILITY_TIMEOUT=7200

# CELERY_RATE_LIMIT: Default task rate limit. Format: "N/s", "N/m", "N/h"
CELERY_RATE_LIMIT=10/m

# CELERY_MEMORY_WARNING_MB: RSS threshold in MB for memory warnings
CELERY_MEMORY_WARNING_MB=1400

# REPORTS_DIR: Directory where generated PDF/Excel reports are stored
REPORTS_DIR=/tmp/sowknow_reports

# ============================================================================
# ALERT NOTIFICATION CONFIGURATION
# ============================================================================
# TELEGRAM_ADMIN_CHAT_ID: Chat ID that receives admin alert messages
TELEGRAM_ADMIN_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# SENDGRID_API_KEY: API key for sending email alerts via SendGrid
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY_HERE

# ALERT_FROM_EMAIL: Sender address for system alert emails
ALERT_FROM_EMAIL=alerts@yourdomain.com

# ADMIN_EMAILS: Comma-separated list of admin email addresses that receive alerts
ADMIN_EMAILS=admin@yourdomain.com
