#!/bin/bash
# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Pre-Commit Hook: Auto-regenerate Architecture Maps & Code Intelligence     ║
# ║  Ensures cache.graph.* and SCIP/LSIF indexes stay synchronized with code.   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

set -euo pipefail

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../scripts/structural_audit" && pwd)"

echo -e "${YELLOW}🧠 Map-First: Checking if architecture maps need regeneration...${NC}"

# Only regenerate if Python or TS/TSX files changed
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

NEEDS_REGEN=false
if echo "$CHANGED_FILES" | grep -qE '^backend/.*\.py$'; then
    NEEDS_REGEN=true
fi
if echo "$CHANGED_FILES" | grep -qE '^frontend/.*\.(ts|tsx)$'; then
    NEEDS_REGEN=true
fi

if [ "$NEEDS_REGEN" = false ]; then
    echo -e "${GREEN}✓ No source files changed. Skipping map regeneration.${NC}"
    exit 0
fi

echo "🔄 Source changes detected. Regenerating architecture maps..."
bash "${SCRIPT_DIR}/generate_all_maps.sh"

# Stage updated maps
git add -f scripts/structural_audit/cache.graph.backend.py 2>/dev/null || true
git add -f scripts/structural_audit/cache.graph.frontend.ts 2>/dev/null || true

echo -e "${GREEN}✅ Maps regenerated and staged.${NC}"

# Also regenerate SCIP/LSIF indexes
echo "🔄 Regenerating code intelligence indexes..."
bash "${SCRIPT_DIR}/generate_scip.sh"

# Stage indexes
git add -f .context/scip/ 2>/dev/null || true

echo -e "${GREEN}✅ Code intelligence indexes regenerated and staged.${NC}"
exit 0
