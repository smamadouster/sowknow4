# ===================================
# ⚠️ SECURITY WARNING - NEVER COMMIT REAL CREDENTIALS ⚠️
# ===================================
# This file is tracked in git. NEVER include real API keys, secrets, or tokens.
# Copy this file to .env and update with your actual values.
# NEVER commit the actual .env file to version control.
# All credentials in this file have been replaced with placeholders.
# ===================================

# ===================================
# SOWKNOW Backend Environment Configuration
# ===================================
# This file contains all environment variables required for the SOWKNOW backend service.
# Copy this file to .env and fill in your actual values.
# Use a password manager or secure vault to generate and store credentials.

# ===================================
# DATABASE CONFIGURATION
# ===================================
# PostgreSQL database connection URL with pgvector extension
# Format: postgresql+asyncpg://user:password@host:port/database
# ⚠️ ROTATE THE PASSWORD IMMEDIATELY - exposed in public repository
DATABASE_URL=postgresql+asyncpg://sowknow:YOUR_DATABASE_PASSWORD_HERE@db:5432/sowknow

# ===================================
# REDIS CONFIGURATION
# ===================================
# Redis connection URL for caching, Celery broker, and session management
REDIS_URL=redis://redis:6379/0

# ===================================
# SECURITY CONFIGURATION - CRITICAL FOR PRODUCTION
# ===================================
# These settings control CORS and TrustedHost security middleware.
# In production, BOTH must be set to prevent security vulnerabilities.

# ALLOWED_ORIGINS: Comma-separated list of allowed frontend origins
#   - NEVER use wildcard "*" with credentials (security vulnerability)
#   - Must include full URLs with protocol (http:// or https://)
#   - Required in production, defaults to localhost in development
#   - Example Production: https://sowknow.gollamtech.com,https://www.sowknow.gollamtech.com
#   - Example Development: http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ALLOWED_HOSTS: Comma-separated list of allowed hostnames
#   - Prevents Host header injection attacks
#   - Use "*" only for development (insecure in production)
#   - Required in production, defaults to wildcard in development
#   - Example Production: sowknow.gollamtech.com,www.sowknow.gollamtech.com
#   - Example Development: *
ALLOWED_HOSTS=*

# ===================================
# AUTHENTICATION & SECURITY
# ===================================
# Secret key for JWT token generation (use a strong, random string in production)
# ⚠️ ROTATE THIS SECRET IMMEDIATELY - exposed in public repository
JWT_SECRET=YOUR_JWT_SECRET_HERE

# COOKIE_DOMAIN: Domain for httpOnly authentication cookies
#   - Controls the domain scope for authentication cookies
#   - Set to None (empty) for localhost development
#   - Set to your domain for production (e.g., ".gollamtech.com" for subdomain sharing)
#   - Set to specific domain without leading dot for exact domain match
#   - Example Development: (leave empty)
#   - Example Production: .gollamtech.com (allows app.gollamtech.com and api.gollamtech.com)
# COOKIE_DOMAIN=

# ===================================
# LEGACY APIs (Being Phased Out)
# ===================================
# Moonshot API (Kimi 2.5) - Legacy, being replaced by Gemini
# Kept for reference during migration period
# ⚠️ ROTATE THIS KEY IMMEDIATELY - exposed in public repository
MOONSHOT_API_KEY=YOUR_MOONSHOT_API_KEY_HERE

# ===================================
# OCR CONFIGURATION (PaddleOCR + Tesseract)
# ===================================
# PaddleOCR: Primary OCR engine (CPU-based, multilingual)
# Tesseract: Fallback OCR engine (CPU-based, open source)
# All OCR processing is done locally - zero PII sent to cloud APIs
# Modes: base (1024x1024), large (1280x1280), gundam (multi-pass)
OCR_ENGINE=paddle
OCR_FALLBACK_ENABLED=true
OCR_DEFAULT_MODE=base

# ===================================
# LOCAL LLM CONFIGURATION
# ===================================
# LOCAL_LLM_URL: URL for the shared Ollama instance
# Purpose: Processing confidential documents that never leave the VPS
# Architecture: Shared instance outside SOWKNOW containers (host.docker.internal)
# Model: gemma2:9b-instruct-q4_K_m (multilingual support)
LOCAL_LLM_URL=http://host.docker.internal:11434

# ===================================
# ROLE-BASED ACCESS CONTROL
# ===================================
# Admin user credentials (created on first startup)
# WARNING: Change these default values in production
# ⚠️ ROTATE THESE CREDENTIALS IMMEDIATELY - exposed in public repository
ADMIN_EMAIL=YOUR_ADMIN_EMAIL_HERE
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE
ADMIN_NAME=System Administrator

# ===================================
# TELEGRAM INTEGRATION (Optional)
# ===================================
# TELEGRAM_BOT_TOKEN: Bot token for Telegram notifications
# Purpose: Send alerts for processing failures, system health updates
# Get your token from @BotFather on Telegram
# ⚠️ ROTATE IMMEDIATELY if this was ever committed to the repository
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# BOT_API_KEY: Internal API key authenticating the Telegram bot to the backend
# Must match the value configured in the Telegram bot service
# Generate with: openssl rand -hex 32
# ⚠️ ROTATE IMMEDIATELY if this was ever committed to the repository
BOT_API_KEY=YOUR_BOT_API_KEY_HERE

# ===================================
# APPLICATION SETTINGS
# ===================================
# APP_ENV: Environment mode (development, staging, production)
APP_ENV=development

# APP_NAME: Application identifier for logging and monitoring
APP_NAME=SOWKNOW

# APP_VERSION: Current version of the application
APP_VERSION=1.0.0

# ===================================
# DUAL-LLM ROUTING CONFIGURATION
# ===================================
# PRIVACY_THRESHOLD: Confidence score (0-1) for detecting confidential documents
# Documents scoring above this threshold are routed to Ollama instead of Gemini
# Default: 0.7 (70% confidence required for confidential routing)
PRIVACY_THRESHOLD=0.7

# MAX_CONCURRENT_USERS: Maximum number of simultaneous users allowed
# Prevents resource exhaustion on shared VPS (16GB total, 6.4GB for SOWKNOW)
MAX_CONCURRENT_USERS=5

# ===================================
# DOCUMENT PROCESSING
# ===================================
# OCR_BATCH_SIZE: Number of pages to process in a single OCR request
# Higher values = faster processing but more memory usage
# Default: 10 (balanced for VPS constraints)
OCR_BATCH_SIZE=10

# EMBEDDING_MODEL: Model for generating text embeddings
# Model: multilingual-e5-large (supports FR/EN, ~1.3GB when loaded)
# Loaded in Celery worker memory for vector search
EMBEDDING_MODEL=multilingual-e5-large

# ===================================
# PERFORMANCE & MONITORING
# ===================================
# SEARCH_LATENCY_TARGET: Target response time in seconds for search queries
# Gemini Flash: <3s, Ollama: <8s
SEARCH_LATENCY_TARGET=3

# PROCESSING_THROUGHPUT_TARGET: Documents per hour target
# Used for monitoring and alerting
PROCESSING_THROUGHPUT_TARGET=50

# MEMORY_THRESHOLD_PERCENT: Memory usage percentage that triggers alerts
# Default: 80% of 6.4GB container limit
MEMORY_THRESHOLD_PERCENT=80
