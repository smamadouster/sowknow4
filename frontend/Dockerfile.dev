FROM node:20-alpine

WORKDIR /app

# Accept build-time env vars that Next.js client components need inlined.
# JWT_SECRET must NEVER be passed to the frontend image.
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

COPY package*.json ./

RUN npm install

CMD ["npm", "run", "dev"]
