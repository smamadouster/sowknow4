        <key>SMTP_PASSWORD</key>
        <string>YOUR_GMAIL_APP_PASSWORD_HERE</string>
        <key>REPORT_RECIPIENT</key>
        <string>smamadouster@gmail.com</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/mamadousow/Library/Logs/sowknow-auto-uploader.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/mamadousow/Library/Logs/sowknow-auto-uploader-error.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/mamadousow</string>
</dict>
</plist>
